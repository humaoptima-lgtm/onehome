_vendorGrid\",\"children\":[[\"$\",\"$L1a\",\"v-001\",{\"vendor\":{\"id\":\"v-001\",\"companyName\":\"Nordic Build Co.\",\"slug\":\"nordic-build-co\",\"category\":\"contractor\",\"description\":\"Award-winning general contractor specializing in Scandinavian-inspired renovations. We blend Nordic design principles with local craftsmanship to create spaces that are both beautiful and functional.\",\"story\":\"Founded in 2015 by master builders who trained in Sweden and Denmark, Nordic Build Co. has grown from a small workshop to one of the region's most respected renovation firms. Our philosophy centers on clean lines, natural materials, and spaces that breathe.\",\"rating\":4.9,\"reviewCount\":124,\"projectsCompleted\":120,\"yearsExperience\":9,\"startingPrice\":15000,\"verified\":true,\"featured\":true,\"responseTime\":\"< 2 hours\",\"coverImage\":\"/images/property-1.png\",\"profileImage\":\"/images/property-1.png\",\"portfolioThumbnails\":[\"/images/property-1.png\",\"/images/property-3.png\",\"/images/property-5.png\"],\"specializations\":[\"Full Remodel\",\"Extensions\",\"Kitchen Renovation\",\"Bathroom Renovation\"],\"serviceArea\":[\"Stockholm\",\"Gothenburg\",\"Malmö\"],\"teamSize\":24,\"packages\":[{\"id\":\"pk-001\",\"name\":\"Refresh\",\"tier\":\"basic\",\"description\":\"Essential cosmetic updates to transform your space.\",\"startingPrice\":15000,\"features\":[\"Surface renovation\",\"Paint & finishing\",\"Basic fixture updates\",\"2D design plan\"],\"deliveryTime\":\"2-4 weeks\",\"revisions\":2},{\"id\":\"pk-002\",\"name\":\"Transform\",\"tier\":\"standard\",\"description\":\"Comprehensive renovation with quality upgrades.\",\"startingPrice\":45000,\"features\":[\"Layout optimization\",\"Premium materials\",\"Custom cabinetry\",\"3D design visualization\",\"Project management\"],\"deliveryTime\":\"6-10 weeks\",\"revisions\":3},{\"id\":\"pk-003\",\"name\":\"Signature\",\"tier\":\"premium\",\"description\":\"High-end renovation with bespoke design elements.\",\"startingPrice\":95000,\"features\":[\"Complete redesign\",\"Imported materials\",\"Smart home integration\",\"Architectural details\",\"Dedicated project manager\",\"Post-completion warranty\"],\"deliveryTime\":\"10-16 weeks\",\"revisions\":5},{\"id\":\"pk-004\",\"name\":\"Atelier\",\"tier\":\"luxury\",\"description\":\"Museum-quality renovation by our master craftsmen.\",\"startingPrice\":200000,\"features\":[\"All Signature features\",\"Rare material sourcing\",\"Custom furniture design\",\"Art curation\",\"Concierge service\",\"Lifetime structural warranty\"],\"deliveryTime\":\"16-24 weeks\",\"revisions\":-1}],\"portfolio\":[{\"id\":\"port-001\",\"title\":\"Östermalm Classic Revival\",\"description\":\"Complete renovation of a 180sqm 1920s apartment, preserving original features while adding modern luxury.\",\"category\":\"Full Remodel\",\"images\":[\"/images/property-1.png\",\"/images/property-3.png\"],\"beforeImage\":\"/images/property-5.png\",\"afterImage\":\"/images/property-1.png\",\"budget\":185000,\"duration\":\"14 weeks\",\"style\":\"Scandinavian Modern\"},{\"id\":\"port-002\",\"title\":\"Minimalist Kitchen Studio\",\"description\":\"Custom kitchen with handleless cabinetry, Corian countertops, and integrated appliances.\",\"category\":\"Kitchen Renovation\",\"images\":[\"/images/property-3.png\"],\"beforeImage\":\"/images/property-4.png\",\"afterImage\":\"/images/property-3.png\",\"budget\":52000,\"duration\":\"6 weeks\",\"style\":\"Modern Minimalist\"}],\"reviews\":[{\"id\":\"rev-001\",\"userId\":\"u-001\",\"userName\":\"Anna Svensson\",\"userAvatar\":\"\",\"rating\":5,\"title\":\"Exceptional craftsmanship\",\"comment\":\"Nordic Build transformed our 1920s apartment into a modern masterpiece while preserving all the original character. The team was professional, punctual, and their attention to detail is second to none.\",\"projectType\":\"Full Remodel\",\"createdAt\":\"2024-10-15T10:00:00Z\",\"helpful\":23},{\"id\":\"rev-002\",\"userId\":\"u-002\",\"userName\":\"Marcus Berg\",\"userAvatar\":\"\",\"rating\":5,\"title\":\"Dream kitchen realized\",\"comment\":\"They built the kitchen of our dreams. The design process was collaborative and the execution was flawless. Highly recommend for anyone looking for premium quality.\",\"projectType\":\"Kitchen Renovation\",\"createdAt\":\"2024-09-20T14:00:00Z\",\"helpful\":15}],\"faq\":[{\"question\":\"What areas do you serve?\",\"answer\":\"We primarily serve Stockholm, Gothenburg, and Malmö. For luxury projects, we consider locations nationwide.\"},{\"question\":\"How long does a typical renovation take?\",\"answer\":\"It depends on scope. A kitchen renovation typically takes 4-8 weeks, while a full apartment renovation takes 10-16 weeks.\"},{\"question\":\"Do you offer a warranty?\",\"answer\":\"Yes, we offer a 5-year warranty on all structural work and a 2-year warranty on fixtures and finishes.\"},{\"question\":\"Can I stay in my home during renovation?\",\"answer\":\"For smaller projects yes, but for full renovations we recommend arranging alternative accommodation for the best results and your comfort.\"}],\"materialsUsed\":[{\"name\":\"White Oak Engineered Flooring\",\"brand\":\"Kährs\"},{\"name\":\"Quartz Countertops\",\"brand\":\"Caesarstone\"},{\"name\":\"Fixtures\",\"brand\":\"Vola\"},{\"name\":\"Kitchen Systems\",\"brand\":\"Bulthaup\"}],\"createdAt\":\"2023-01-15T08:00:00Z\"}}],\"$L1b\",\"$L1c\",\"$L1d\",\"$L1e\",\"$L1f\"]}],\"$L20\"]}]\n1b:[\"$\",\"$L1a\",\"v-002\",{\"vendor\":{\"id\":\"v-002\",\"companyName\":\"Studio Aris\",\"slug\":\"studio-aris\",\"category\":\"interior-designer\",\"description\":\"Boutique interior design studio creating harmonious living spaces that reflect your personality. Specializing in Japandi, Scandinavian, and contemporary luxury aesthetics.\",\"rating\":5,\"reviewCount\":89,\"projectsCompleted\":85,\"yearsExperience\":7,\"startingPrice\":2500,\"verified\":true,\"featured\":true,\"responseTime\":\"< 4 hours\",\"coverImage\":\"