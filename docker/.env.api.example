# ═══════════════════════════════════════
# One Home API — Environment Variables
# Copy this file as .env.api and fill in real values
# ═══════════════════════════════════════

# Server
NODE_ENV=development
PORT=3001

# Database (uses docker postgres service in dev)
DATABASE_URL="postgresql://onehome_user:onehome_pg_dev@postgres:5432/onehome_db"

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=onehome_redis_dev

# Meilisearch
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=onehome_meili_dev_key

# CORS — allowed origins (comma separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# JWT
JWT_SECRET=dev-jwt-secret-change-in-production-64chars-minimum-please
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudflare R2 (optional for dev)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=onehome-storage
# R2_PUBLIC_URL=https://r2.onehome.id

# Sentry (optional for dev)
# SENTRY_DSN=
